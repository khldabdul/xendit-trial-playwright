{
  "name": "xendit-trial-playwright",
  "version": "1.0.0",
  "description": "TypeScript test automation framework for Xendit apps",
  "type": "module",
  "scripts": {
    "setup": "pnpm install && pnpm exec playwright install chromium",
    "test": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js 'apps/**/*.feature'",
    "test:headed": "HEADED=true NODE_OPTIONS='--import tsx --no-warnings' cucumber-js 'apps/**/*.feature'",
    "test:filter": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js",
    "test:e2e": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js -p e2e",
    "test:e2e:headed": "HEADED=true NODE_OPTIONS='--import tsx --no-warnings' cucumber-js -p e2e",
    "test:api": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js -p api",
    "test:dry-run": "NODE_OPTIONS='--import tsx --no-warnings' cucumber-js --dry-run --format progress",
    "report": "node scripts/generate-bdd-report.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "check": "pnpm type-check && pnpm lint && pnpm format:check",
    "clean": "rm -rf cucumber-report",
    "prepare": "husky"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-playwright": "^1.8.0",
    "globals": "^15.14.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "prettier": "^3.3.0",
    "totp-generator": "^2.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.19.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
