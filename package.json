{
  "name": "xendit-trial-playwright",
  "version": "1.0.0",
  "description": "TypeScript test automation framework for Xendit apps",
  "type": "module",
  "scripts": {
    "setup": "pnpm install && pnpm exec playwright install chromium",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test -m smoke",
    "test:api": "playwright test apps/api",
    "test:e2e": "playwright test apps/e2e",
    "test:parallel": "playwright test --workers=4",
    "test:with-video": "playwright test --video=on",
    "test:with-trace": "playwright test --trace=on",
    "test:with-har": "ENABLE_HAR=true pnpm test apps/e2e",
    "test:with-all-artifacts": "playwright test --video=on --trace=on && ENABLE_HAR=true pnpm test apps/e2e",
    "report:allure": "allure generate allure-results -o allure-report --clean",
    "report:open": "allure open allure-report",
    "report:serve": "allure open allure-report",
    "report:history": "allure generate allure-results -o allure-report --clean --history",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "check": "pnpm type-check && pnpm lint && pnpm format:check",
    "clean": "rm -rf test-results allure-results playwright-report allure-report",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "allure-commandline": "^2.29.0",
    "allure-js-commons": "^3.4.5",
    "allure-playwright": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-playwright": "^1.8.0",
    "globals": "^15.14.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.3.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.19.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
