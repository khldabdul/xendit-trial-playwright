# Environment Configuration
ENV=dev

# Browser Options
HEADED=false
BROWSER=chromium

# Parallel Execution
WORKERS=4

# Multi-Viewport Testing
# Set to 'true' to enable cross-browser/device testing (multiplies API calls and test time)
# Default: false (single viewport for faster, quota-efficient testing)
MULTI_VIEWPORT=false

# Video/Trace Options
VIDEO=retain-on-failure
TRACE=retain-on-failure

# Report Attachments
# Set to 'false' to only attach screenshots/videos on failed tests (default: true)
ATTACH_ON_PASS=true

# HAR Recording
ENABLE_HAR=false

# API Keys and URLs
# Add your Xendit API keys here for API Testing
# Xendit Test Credentials
# Create a test account to get these credentials
XENDIT_USERNAME="your-test-email@example.com"
XENDIT_PASSWORD="your-secure-test-password"
XENDIT_SECRET_KEY="xnd_development_..."
XENDIT_API_URL="https://api.xendit.co"
XENDIT_PUBLIC_KEY=xnd_public_development_...
XENDIT_TOTP_SECRET="your_authenticator_setup_secret_key"
WEBHOOK_SITE_TOKEN=your_webhook_site_token_here
# Override URLs (optional)
BASE_URL=

# Playwright Options
SLOWMO=0
